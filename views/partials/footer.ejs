<script>
    let theme = document.getElementById('theme-toggle');
    theme.addEventListener ('click', function(event) {
        if(document.getElementById("main-page").classList.contains('dark-theme')){
            document.getElementById("main-page").classList.add("light-theme");
            document.getElementById("main-page").classList.remove("dark-theme");
            document.getElementById('theme-text').innerHTML = 'Light Mode';
        } else {
            document.getElementById("main-page").classList.add("dark-theme");
            document.getElementById("main-page").classList.remove("light-theme");
            document.getElementById('theme-text').innerHTML = 'Dark Mode';
        }
    })
</script>
