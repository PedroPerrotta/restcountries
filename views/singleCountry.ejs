<%- include("partials/header"); -%>

<div class="container-fluid mb-5 p-0">
  <a type="button" class="mx-6 btn btn-secondary back-button" href="/">
    <i class="fas fa-long-arrow-alt-left left-arrow-icon"></i> Back
  </a>
</div>

<div class="container-fluid mb-5 p-0">
  <div class="row">
    <div class="col-6 single-country-flag">
      <img class="mx-6 country-flag" src=" <%= country.flags.png %> " />
    </div>

    <div class="single-country-information col-5 mt-5 ms-0">
      <div class="country-name"><%= country.name.common %></div>
      <div class="row mt-4">
        <div class="col-6">
          <div class="country-data single-data mb-2">
            Native Name: <%= country.name.common %>
          </div>
          <div class="country-data single-data mb-2">
            Population: <%= (country.population).toLocaleString('en-US') %>
          </div>
          <div class="country-data single-data mb-2">
            Region: <%= country.region %>
          </div>
          <div class="country-data single-data mb-2">
            Sub Region: <%= country.subregion %>
          </div>
          <div class="country-data single-data mb-2">
            Capital: <%= country.capital %>
          </div>
        </div>
        <div class="col-6">
          <div class="country-data single-data mb-2">
            Top Level Domain: <%= country.tld %>
          </div>
          <div class="country-data single-data mb-2">
            Currencies: <%= currencies %>
          </div>
          <div class="country-data single-data mb-2">
            Languages: <%= languages %>
          </div>
        </div>
      </div>
      <div class="row borders-section">
        <div class="country-data col-3 single-data">Border Countries:</div>
        <div class="col-9">
          <% var y = 0; %> <% for (y; y < borders.length - 3; y = y + 3) { %>
          <div class="row">
            <div class="border-country col-4 mb-2 p-0 single-data">
              <%= borders[y] %>
            </div>
            <div class="border-country col-4 mb-2 p-0 single-data">
              <%= borders[y + 1] %>
            </div>
            <div class="border-country col-4 mb-2 p-0 single-data">
              <%= borders[y + 2] %>
            </div>
          </div>
          <% } %>
          <div class="row">
            <% for (y; y < borders.length; y++) { %>
              <div class="border-country col-4 mb-2 p-0 single-data">
                <%= borders[y] %>
              </div>
            <% } %>
            <% for(y = 0; y < (borders.length) % 4; y++) { %> <% if((y + 1)===
              (borders.length % 4)) { %>
              <div class="col mb-4 mb-2 p-0"></div>
              <% } else { %>
              <div class="col mb-4 mb-2 p-0"></div>
              <% } %> <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("partials/footer"); -%>